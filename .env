# Telegram bot (control interface)
TELEGRAM_BOT_TOKEN=

# Pexels API (TikTok video generator stock backgrounds)
PEXELS_API_KEY=

# X / Twitter (input analyzer)
X_API_BEARER_TOKEN=

# Database (optional, defaults to SQLite local)
DATABASE_URL=

# CORS (comma-separated origins, defaults to *)
ALLOWED_ORIGINS=*

# LLM (optional, defaults to MockLLM)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
